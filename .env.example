# 安装状态（false 表示未安装）
INSTALL_DONE=false

# 数据库驱动（sqlite 或 mysql）
DB_DRIVER=sqlite

# MySQL 连接配置（DB_DRIVER=mysql 时使用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=music_parser
MYSQL_PARAMS=charset=utf8mb4&parseTime=True&loc=Local

# 安全配置（安装后自动生成）
JWT_SECRET=
APP_MASTER_KEY=
